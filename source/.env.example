# ---------------------------------------------------------------------------
# Takeawaypack Website — environment variables
# Copy this file to `.env.local` (never commit real secrets) and fill in values.
# On Vercel, add the same variables in Project Settings -> Environment Variables.
# ---------------------------------------------------------------------------

# --- Site / data adapter ---------------------------------------------------
# Optional. Absolute or relative path to the folder that holds the imported
# Feishu Base JSON (site-info.raw.json, products.raw.json, fields.*.json).
# If unset, the adapter auto-detects ../content/imports relative to this app.
# DATA_IMPORT_DIR=

# Public site URL used for canonical links, sitemap and Open Graph.
# Set this to the production Vercel domain, e.g. https://takeawaypack-website.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase --------------------------------------------------------------
# Public URL of your Supabase project (Project Settings -> API -> Project URL).
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (Project Settings -> API -> anon public). Safe to expose.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (Project Settings -> API -> service_role). KEEP SECRET.
# Used only on the server (API route) to insert inquiry rows. Never prefix
# with NEXT_PUBLIC_ and never ship to the browser bundle.
SUPABASE_SERVICE_ROLE_KEY=

# When SUPABASE_SERVICE_ROLE_KEY is absent, the inquiry API falls back to
# "demo mode" (validates and echoes the payload, stores nothing). Set the key
# in production so submissions are persisted to the `inquiries` table.
